figure.figsize: 3.3, 2.5
figure.dpi: 150

font.size: 8
font.family: Latin Modern Roman, Source Han Sans SC
mathtext.fontset: cm

lines.linewidth: 1.5
lines.markersize: 4

axes.grid: True
axes.labelsize: large
axes.prop_cycle: cycler('color', 'bgcmy') + cycler('linestyle', ['--', '-.', ':', '--', '-.'])

legend.fancybox: False
legend.frameon: True
legend.framealpha: None
legend.facecolor: inherit
legend.edgecolor: inherit

savefig.format: pdf
savefig.bbox: tight
